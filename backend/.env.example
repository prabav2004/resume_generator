# ==========================================
# APPLICATION
# ==========================================

ENVIRONMENT=production
DEBUG=false
ENABLE_DOCS=false
LOG_LEVEL=INFO


# ==========================================
# FRONTEND / CORS
# Replace with your real Vercel URL
# ==========================================

CORS_ORIGINS=https://resume-generator-prabakaran2.vercel.app
FRONTEND_URL=https://resume-generator-prabakaran2.vercel.app


# ==========================================
# DATABASE
# Local development only
# For Railway, use the Railway Postgres URL
# ==========================================

DATABASE_URL=sqlite:///./resume_generator.db


# ==========================================
# OPENAI — PRIMARY AI PROVIDER
# ==========================================

OPENAI_API_KEY=your_real_openai_api_key
OPENAI_MODEL=gpt-4o-mini


# ==========================================
# GROQ — FALLBACK AI PROVIDER
# ==========================================

GROQ_API_KEY=your_new_groq_api_key
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=openai/gpt-oss-120b
LLM_PRIMARY_PROVIDER=groq


# ==========================================
# LANGSMITH
# ==========================================

LANGSMITH_API_KEY=your_real_langsmith_api_key
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=resume-generator


# ==========================================
# HUGGING FACE
# ==========================================

HUGGINGFACEHUB_API_TOKEN=your_real_huggingface_token


# ==========================================
# MODEL SETTINGS
# ==========================================

MODEL_PROVIDER=huggingface
HF_SKILL_MODEL=facebook/bart-large-mnli
